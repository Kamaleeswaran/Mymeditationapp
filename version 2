<script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, GoogleAuthProvider, signInWithPopup, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Firebase Setup
        let app, db, auth;
        let currentUser = null;
        let useFirebase = false;
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'meditation-app-default';

        try {
            if (typeof __firebase_config !== 'undefined') {
                const firebaseConfig = JSON.parse(__firebase_config);
                app = initializeApp(firebaseConfig);
                db = getFirestore(app);
                auth = getAuth(app);
                useFirebase = true;
                
                onAuthStateChanged(auth, (user) => {
                    currentUser = user;
                    if (user) {
                        updateAuthUI(user);
                        loadData(); // reload data from firestore
                    } else {
                        resetAuthUI();
                    }
                });

                if (typeof __initial_auth_token !== 'undefined') {
                    signInWithCustomToken(auth, __initial_auth_token).catch(console.error);
                }
            }
        } catch (e) {
            console.warn("Firebase initialization skipped. Using memory mode.");
        }

        // --- NEW: Google Login Flow ---
        // Handles Google account authorization. Google manages the OTP/verification challenges directly.
        async function handleGoogleLogin() {
            if (!useFirebase || !auth) {
                showToast("Firebase configuration is missing for Cloud Auth.");
                return;
            }
            const provider = new GoogleAuthProvider();
            try {
                showToast("Opening Google Secure Sign-In...");
                const result = await signInWithPopup(auth, provider);
                const user = result.user;
                showToast(`Welcome, ${user.displayName || 'Mindful User'}!`);
            } catch (error) {
                console.error("Google Authentication failed:", error);
                showToast(`Authentication Error: ${error.message}`);
            }
        }

        // UI Helpers for Authentication State
        function updateAuthUI(user) {
            const authBtn = document.getElementById('btn-google-login');
            if (authBtn) {
                authBtn.innerHTML = `<i class="ph ph-user-circle text-xl text-emerald-600"></i> <span class="text-xs font-medium text-slate-700 truncate max-w-[120px]">${user.displayName || 'Signed In'}</span>`;
                authBtn.disabled = true;
            }
        }

        function resetAuthUI() {
            const authBtn = document.getElementById('btn-google-login');
            if (authBtn) {
                authBtn.innerHTML = `<i class="ph ph-google-logo text-xl"></i> <span class="text-xs font-medium">Sign Up / Login</span>`;
                authBtn.disabled = false;
            }
        }

        // --- DATA: 50 Mindfulness Quotes ---
        const quotes = [
            { text: "Peace comes from within. Do not seek it without.", author: "Buddha" },
            { text: "You can't stop the waves, but you can learn to surf.", author: "Jon Kabat-Zinn" },
            { text: "If you want to conquer the anxiety of life, live in the moment, live in the breath.", author: "Amit Ray" },
            { text: "Just when you feel you have no time to relax, know this is the moment you most need to relax.", author: "Matt Haig" },
            { text: "Nowhere can man find a quieter or more untroubled retreat than in his own soul.", author: "Marcus Aurelius" },
            { text: "Be present, be patient, be gentle, be kind… everything else will take care of itself.", author: "Andy Puddicombe" },
            { text: "When you're quiet, everything settles on the floor of your mind like sediment in undisturbed still water.", author: "Megan Monahan" },
            { text: "Between stimulus and response there is a space. In that space is our power to choose our response.", author: "Victor Frankl" },
            { text: "Breathe in the good. Breathe out the bad.", author: "Unknown" },
            { text: "Be happy in the moment, that's enough. Each moment is all we need, not more.", author: "Mother Teresa" },
            { text: "Be content with what you have; rejoice in the way things are. When you realize there is nothing lacking, the whole world belongs to you.", author: "Lao Tzu" },
            { text: "Meditation practice isn't about trying to throw ourselves away and become something better. It's about befriending who we are already.", author: "Pema Chödrön" },
            { text: "Ask yourself: Where am I? Answer: Here. Ask yourself: What time is it? Answer: Now. Say it until you can hear it.", author: "Ram Dass" },
            { text: "Mindfulness is simply being aware of what is happening right now without wishing it were different.", author: "James Baraz" },
            { text: "When you arise in the morning, think of what a precious privilege it is to be alive - to breathe, to think, to enjoy, to love.", author: "Marcus Aurelius" },
            { text: "We already have everything we are looking for, everything we want to become.", author: "Thich Nhat Hanh" },
            { text: "If you want to be happy, practice compassion.", author: "Dalai Lama" },
            { text: "Wherever you go, there you are.", author: "Jon Kabat-Zinn" },
            { text: "Your actions are your only true belongings.", author: "Allan Lokos" },
            { text: "The little things? The little moments? They aren't little.", author: "Jon Kabat-Zinn" },
            { text: "Mindfulness isn't difficult, we just need to remember to do it.", author: "Sharon Salzberg" },
            { text: "The most precious gift we can offer others is our presence.", author: "Thich Nhat Hanh" },
            { text: "Feelings come and go like clouds in a windy sky. Conscious breathing is my anchor.", author: "Thich Nhat Hanh" },
            { text: "Life is a dance. Mindfulness is witnessing that dance.", author: "Amit Ray" },
            { text: "When you bow, you should just bow; when you sit, you should just sit; when you eat, you should just eat.", author: "Shunryu Suzuki" },
            { text: "Looking at beauty in the world, is the first step of purifying the mind.", author: "Amit Ray" },
            { text: "The best way to capture moments is to pay attention. This is how we cultivate mindfulness.", author: "Jon Kabat-Zinn" },
            { text: "Rejoicing in ordinary things is not sentimental or trite. It actually takes guts.", author: "Pema Chödrön" },
            { text: "We have only now, only this single eternal moment opening and unfolding before us, day and night.", author: "Jack Kornfield" },
            { text: "Walk as if you are kissing the Earth with your feet.", author: "Thich Nhat Hanh" },
            { text: "Live the actual moment. Only this actual moment is life.", author: "Thích Nhất Hạnh" },
            { text: "Much of spiritual life is self-acceptance, maybe all of it.", author: "Jack Kornfield" },
            { text: "Respond; don't react. Listen; don't talk. Think; don't assume.", author: "Raji Lukkoor" },
            { text: "Don't believe everything you think. Thoughts are just that – thoughts.", author: "Allan Lokos" },
            { text: "There is something wonderfully bold and liberating about saying yes to our entire imperfect and messy life.", author: "Tara Brach" },
            { text: "Don't let life harden your heart.", author: "Pema Chödrön" },
            { text: "You only lose what you cling to.", author: "Buddha" },
            { text: "Our life is shaped by our mind, for we become what we think.", author: "Buddha" },
            { text: "Each morning we are born again. What we do today is what matters most.", author: "Buddha" },
            { text: "Nothing is forever except change.", author: "Buddha" },
            { text: "Be where you are, otherwise you will miss your life.", author: "Buddha" },
            { text: "Impermanence is a principle of harmony. When we don't struggle against it, we are in harmony with reality.", author: "Pema Chödrön" },
            { text: "Mindfulness is the root of all the methods that tame the mind.", author: "Patrul Rinpoche" },
            { text: "At certain times, a silent mind is very important, but 'silent' does not mean closed.", author: "Lama Yeshe" },
            { text: "Whatever is not yours: let go of it. Your letting go of it will be for your long-term happiness & benefit.", author: "Buddha" },
            { text: "Imperfection is not our personal problem – it is a natural part of living.", author: "Tara Brach" },
            { text: "Let go of the battle. Breathe quietly and let it be.", author: "Jack Kornfield" },
            { text: "Nothing is wrong. Whatever is happening is just 'real life.'", author: "Sylvia Boorstein" },
            { text: "If you have time to be mindful, you have time to meditate.", author: "Ajahn Chah" },
            { text: "Mindfulness is life. Whenever we don't have mindfulness, when we are heedless, it's as if we are dead.", author: "Ajahn Chah" }
        ];

        // --- STATE ---
        let timerInterval = null;
        let timeLeft = 600; // default 10 mins in seconds
        let totalSessionTime = 600; 
        let isRunning = false;
        let isSoundEnabled = true;
        let currentSessionStartTime = null;
        
        // Tone.js Synth nodes
        let droneSynth = null;
        let bellSynth = null;
        let isAudioInitialized = false;

        // Data Storage Structure
        let appData = {
            sessions: [], // { date: string, durationSec: number, mood: string, note: string }
            lastLogin: null
        };

        // DOM Elements
        const elTimeDisplay = document.getElementById('time-display');
        const elDurationSlider = document.getElementById('duration-slider');
        const elSliderValue = document.getElementById('slider-value');
        const btnStart = document.getElementById('btn-start');
        const btnPause = document.getElementById('btn-pause');
        const btnStop = document.getElementById('btn-stop');
        const elDurationSelector = document.getElementById('duration-selector');
        const timerStatus = document.getElementById('timer-status');
        const timerSection = document.getElementById('view-timer');
        const statsSection = document.getElementById('view-stats');
        
        const navTimer = document.getElementById('nav-timer');
        const navStats = document.getElementById('nav-stats');

        const modalFeedback = document.getElementById('modal-feedback');
        const modalFeedbackContent = document.getElementById('modal-feedback-content');
        const btnSaveFeedback = document.getElementById('btn-save-feedback');
        const btnSkipFeedback = document.getElementById('btn-skip-feedback');
        const feedbackNote = document.getElementById('feedback-note');
        const moodButtons = document.querySelectorAll('.mood-btn');
        let selectedMood = null;

        const toast = document.getElementById('toast');
        const toastMsg = document.getElementById('toast-msg');

        // --- INITIALIZATION ---
        function initApp() {
            loadData();
            displayRandomQuote();
            updateTimeDisplay(elDurationSlider.value * 60);
            
            const today = new Date().toDateString();
            if (appData.lastLogin !== today) {
                appData.lastLogin = today;
                saveData();
            }

            // Bind the Google Login click event listener
            const authBtn = document.getElementById('btn-google-login');
            if (authBtn) {
                authBtn.addEventListener('click', handleGoogleLogin);
            }
        }

        // --- AUDIO (Tone.js) ---
        async function initAudio() {
            if (isAudioInitialized) return;
            
            await Tone.start();
            
            droneSynth = new Tone.PolySynth(Tone.Synth, {
                oscillator: { type: "sine" },
                envelope: { attack: 2, decay: 1, sustain: 1, release: 4 },
                volume: -20
            }).toDestination();

            const chorus = new Tone.Chorus(4, 2.5, 0.5).toDestination().start();
            const reverb = new Tone.Reverb({ decay: 5, wet: 0.5 }).toDestination();
            droneSynth.connect(chorus);
            droneSynth.connect(reverb);

            bellSynth = new Tone.MetalSynth({
                frequency: 400,
                envelope: { attack: 0.01, decay: 4, release: 2 },
                harmonicity: 3.1,
                modulationIndex: 32,
                resonance: 4000,
                octaves: 1.5,
                volume: -10
            }).connect(reverb).toDestination();

            isAudioInitialized = true;
        }

        function playStartBell() {
            if (!isSoundEnabled || !bellSynth) return;
            bellSynth.triggerAttackRelease("4n");
        }

        function playEndBell() {
            if (!isSoundEnabled || !bellSynth) return;
            bellSynth.triggerAttackRelease("4n", "+0");
            bellSynth.triggerAttackRelease("4n", "+1.5");
            bellSynth.triggerAttackRelease("4n", "+3");
        }

        function startDrone() {
            if (!isSoundEnabled || !droneSynth || !isRunning) return;
            droneSynth.triggerAttack(["C3", "E3", "G3", "C4"]);
        }

        function stopDrone() {
            if (droneSynth) {
                try { droneSynth.triggerRelease(["C3", "E3", "G3", "C4"]); } catch(e){}
            }
        }

        document.getElementById('btn-sound-toggle').addEventListener('click', () => {
            isSoundEnabled = !isSoundEnabled;
            const icon = document.getElementById('sound-icon');
            if (isSoundEnabled) {
                icon.className = "ph-fill ph-speaker-high text-xl";
                document.getElementById('btn-sound-toggle').classList.replace('text-slate-400', 'text-emerald-600');
                if (isRunning) startDrone();
            } else {
                icon.className = "ph ph-speaker-x text-xl text-slate-400";
                document.getElementById('btn-sound-toggle').classList.replace('text-emerald-600', 'text-slate-400');
                stopDrone();
            }
        });

        // --- TIMER LOGIC ---
        function formatTime(seconds) {
            const m = Math.floor(seconds / 60).toString().padStart(2, '0');
            const s = (seconds % 60).toString().padStart(2, '0');
            return `${m}:${s}`;
        }

        function updateTimeDisplay(seconds) {
            elTimeDisplay.textContent = formatTime(seconds);
        }

        function displayRandomQuote() {
            const rand = quotes[Math.floor(Math.random() * quotes.length)];
            document.getElementById('quote-text').textContent = `"${rand.text}"`;
            document.getElementById('quote-author').textContent = `— ${rand.author}`;
        }

        elDurationSlider.addEventListener('input', (e) => {
            if (!isRunning) {
                const mins = e.target.value;
                elSliderValue.textContent = mins;
                timeLeft = mins * 60;
                totalSessionTime = timeLeft;
                updateTimeDisplay(timeLeft);
            }
        });

        btnStart.addEventListener('click', async () => {
            if (!isAudioInitialized) await initAudio();
            
            isRunning = true;
            if (!currentSessionStartTime) currentSessionStartTime = Date.now();
            
            document.body.classList.add('timer-active');
            btnStart.classList.add('hidden');
            elDurationSelector.classList.add('hidden');
            btnPause.classList.remove('hidden');
            btnStop.classList.remove('hidden');
            timerStatus.textContent = "Meditating";
            document.body.style.backgroundColor = '#f0fdf4';
            
            playStartBell();
            setTimeout(startDrone, 2000);

            timerInterval = setInterval(() => {
                timeLeft--;
                updateTimeDisplay(timeLeft);
                if (timeLeft <= 0) {
                    endSession(true);
                }
            }, 1000);
        });

        btnPause.addEventListener('click', () => {
            clearInterval(timerInterval);
            isRunning = false;
            stopDrone();
            btnPause.classList.add('hidden');
            btnStart.classList.remove('hidden');
            timerStatus.textContent = "Paused";
        });

        btnStop.addEventListener('click', () => {
            endSession(false);
        });

        function endSession(completed) {
            clearInterval(timerInterval);
            isRunning = false;
            stopDrone();

            if (completed) {
                playEndBell();
            }

            const elapsedSec = totalSessionTime - timeLeft;
            totalSessionTime = elapsedSec; // Storing actual elapsed seconds for logging

            // Reset UI
            document.body.classList.remove('timer-active');
            btnPause.classList.add('hidden');
            btnStop.classList.add('hidden');
            btnStart.classList.remove('hidden');
            elDurationSelector.classList.remove('hidden');
            timerStatus.textContent = "Ready";
            document.body.style.backgroundColor = '#fdf5f6';
            
            timeLeft = elDurationSlider.value * 60;
            updateTimeDisplay(timeLeft);

            if (totalSessionTime >= 5) {
                showFeedbackModal();
            } else {
                showToast("Session too short to save.");
                resetSessionState();
            }
        }

        function resetSessionState() {
            currentSessionStartTime = null;
            totalSessionTime = elDurationSlider.value * 60;
            selectedMood = null;
            feedbackNote.value = "";
            moodButtons.forEach(b => b.classList.add('grayscale'));
        }

        // --- NAVIGATION CONTROLS ---
        navTimer.addEventListener('click', () => {
            timerSection.classList.remove('hidden');
            statsSection.classList.add('hidden');
            navTimer.className = "text-emerald-800 hover:text-emerald-600 font-medium transition-colors border-b-2 border-emerald-500 pb-1";
            navStats.className = "text-slate-500 hover:text-emerald-600 font-medium transition-colors pb-1";
        });

        navStats.addEventListener('click', () => {
            timerSection.classList.add('hidden');
            statsSection.classList.remove('hidden');
            navStats.className = "text-emerald-800 hover:text-emerald-600 font-medium transition-colors border-b-2 border-emerald-500 pb-1";
            navTimer.className = "text-slate-500 hover:text-emerald-600 font-medium transition-colors pb-1";
            renderCalendarAndStats();
        });

        // --- REFLECTION MODAL LOGIC ---
        function showFeedbackModal() {
            modalFeedback.classList.remove('hidden');
            setTimeout(() => {
                modalFeedback.classList.remove('opacity-0');
                modalFeedbackContent.classList.remove('scale-95');
            }, 50);
        }

        function hideFeedbackModal() {
            modalFeedback.classList.add('opacity-0');
            modalFeedbackContent.classList.add('scale-95');
            setTimeout(() => {
                modalFeedback.classList.add('hidden');
                resetSessionState();
            }, 300);
        }

        moodButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                moodButtons.forEach(b => b.classList.add('grayscale'));
                btn.classList.remove('grayscale');
                selectedMood = btn.getAttribute('data-mood');
            });
        });

        btnSaveFeedback.addEventListener('click', () => {
            const entry = {
                date: new Date().toISOString(),
                durationSec: totalSessionTime,
                mood: selectedMood || "Neutral",
                note: feedbackNote.value.trim()
            };
            appData.sessions.push(entry);
            saveData();
            hideFeedbackModal();
            showToast("Reflection logged nicely.");
            displayRandomQuote();
        });

        btnSkipFeedback.addEventListener('click', () => {
            const entry = {
                date: new Date().toISOString(),
                durationSec: totalSessionTime,
                mood: "Neutral",
                note: ""
            };
            appData.sessions.push(entry);
            saveData();
            hideFeedbackModal();
            displayRandomQuote();
        });

        // --- TOAST NOTIFICATIONS ---
        function showToast(msg) {
            toastMsg.textContent = msg;
            toast.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            }, 3000);
        }

        // --- DATA PERSISTENCE LAYER ---
        async function saveData() {
            const storageKey = `mindful_moments_data_${appId}`;
            localStorage.setItem(storageKey, JSON.stringify(appData));

            if (useFirebase && auth.currentUser) {
                try {
                    await setDoc(doc(db, "users", auth.currentUser.uid), appData);
                } catch (e) {
                    console.error("Error saving backup to Cloud Firestore:", e);
                }
            }
        }

        async function loadData() {
            const storageKey = `mindful_moments_data_${appId}`;
            const local = localStorage.getItem(storageKey);
            if (local) {
                appData = JSON.parse(local);
            }

            if (useFirebase && auth.currentUser) {
                try {
                    const snap = await getDoc(doc(db, "users", auth.currentUser.uid));
                    if (snap.exists()) {
                        appData = snap.data();
                        localStorage.setItem(storageKey, JSON.stringify(appData));
                    }
                } catch (e) {
                    console.error("Cloud retrieval fallback failed:", e);
                }
            }
            renderCalendarAndStats();
        }

        // --- JOURNEY STATS & CALENDAR CALCULATIONS ---
        function renderCalendarAndStats() {
            // Calculations
            let totalSeconds = 0;
            let sessionCount = appData.sessions.length;
            let loggedDates = new Set();

            appData.sessions.forEach(s => {
                totalSeconds += s.durationSec;
                loggedDates.add(new Date(s.date).toDateString());
            });

            const hrs = Math.floor(totalSeconds / 3600);
            const mins = Math.round((totalSeconds % 3600) / 60);
            
            document.getElementById('stat-total-hours').textContent = `${hrs} h ${mins} m`;
            document.getElementById('stat-total-sessions').textContent = sessionCount;

            // Streak Tracking Engine
            let streak = 0;
            let checkDate = new Date();
            
            while (true) {
                if (loggedDates.has(checkDate.toDateString())) {
                    streak++;
                    checkDate.setDate(checkDate.getDate() - 1);
                } else {
                    // Check if they just haven't meditated yet today before breaking
                    if (streak === 0 && checkDate.toDateString() === new Date().toDateString()) {
                        checkDate.setDate(checkDate.getDate() - 1);
                        if (loggedDates.has(checkDate.toDateString())) {
                            streak++;
                            checkDate.setDate(checkDate.getDate() - 1);
                            continue;
                        }
                    }
                    break;
                }
            }

            document.getElementById('stat-streak').textContent = `${streak} ${streak === 1 ? 'day' : 'days'}`;
            const flameIcon = document.getElementById('streak-flame-icon');
            if (streak > 0) {
                flameIcon.className = "ph-fill ph-fire text-3xl fierce-flame text-amber-500";
            } else {
                flameIcon.className = "ph-fill ph-fire text-3xl animate-flame text-slate-300";
            }

            // Journal Lists Injection
            const journalList = document.getElementById('journal-list');
            if (appData.sessions.length === 0) {
                journalList.innerHTML = `<div class="text-center text-slate-400 mt-10 italic">No entries yet. Complete a session to reflect.</div>`;
            } else {
                journalList.innerHTML = [...appData.sessions].reverse().map(s => {
                    const d = new Date(s.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
                    const m = Math.round(s.durationSec / 60);
                    const moodEmojis = { "Struggled": "☁️", "Neutral": "🌤️", "Peaceful": "☀️" };
                    return `
                        <div class="bg-white/60 p-3 rounded-xl border border-slate-100 shadow-sm text-xs">
                            <div class="flex justify-between font-bold text-emerald-900 mb-1">
                                <span>${d} • ${m} min</span>
                                <span>${moodEmojis[s.mood] || "🌤️"}</span>
                            </div>
                            <p class="text-slate-600 italic font-normal">${s.note || "No notes recorded."}</p>
                        </div>
                    `;
                }).join('');
            }

            // Last 7 Days Habit Grid Generation
            const calendarGrid = document.getElementById('calendar-grid');
            calendarGrid.innerHTML = '';
            
            const daysArr = [];
            for (let i = 6; i >= 0; i--) {
                const d = new Date();
                d.setDate(d.getDate() - i);
                daysArr.push(d);
            }

            daysArr.forEach(day => {
                const isMeditated = loggedDates.has(day.toDateString());
                const dayLabel = day.toLocaleDateString(undefined, { weekday: 'narrow' });
                const dayNum = day.getDate();
                const activeClass = isMeditated ? 'bg-emerald-500 text-white font-bold' : 'bg-slate-100 text-slate-400';
                
                const dayEl = document.createElement('div');
                dayEl.className = "flex flex-col items-center gap-1";
                dayEl.innerHTML = `
                    <span class="text-[10px] text-slate-400 uppercase font-bold">${dayLabel}</span>
                    <div class="w-8 h-8 rounded-full flex items-center justify-center ${activeClass} text-xs">
                        ${dayNum}
                    </div>
                `;
                calendarGrid.appendChild(dayEl);
            });
        }

        // Run App
        initApp();
    </script>
</body>
</html>
